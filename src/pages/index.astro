---
import Layout from '../layouts/Layout.astro';
import PortfolioHUD from '../components/PortfolioHUD.jsx';
---

<Layout
  title="Hakon | Fullstack & AI First Engineer Portfolio"
  description="Interactive 3D Rubik's Cube portfolio by Hakon — AI-first engineer building RAG pipelines, multi-agent assistants, and voice interfaces with Python, Next.js, and Google ADK."
>
  <!-- Loading Screen -->
  <div id="loader" class="loader-container">
    <div class="loader-spinner"></div>
    <p class="loader-text" data-i18n="loader">Initializing 3D…</p>
  </div>

  <!-- 3D Canvas -->
  <canvas id="webgl"></canvas>

  <!-- Unified 2D Section Typography Overlays -->
  <div id="section-titles">
    <!-- Welcome (Home) -->
    <div id="title-welcome" class="section-title-container" data-section="welcome">
      <h1 class="section-title-main">XAKON.DEV</h1>
      <div class="section-title-sub">FULLSTACK / AI FIRST ENGINEER</div>
    </div>
    
    <!-- About -->
    <div id="title-about" class="section-title-container" data-section="about">
      <div class="section-eyebrow">01 / ABOUT</div>
      <h2 class="section-title-main">AI-FIRST BUILDS</h2>
      <div class="section-title-sub">IDEA → PRODUCT, FAST</div>
      <p class="section-title-desc">Fullstack AI-first engineer. I ship RAG pipelines, multi-agent assistants, and voice interfaces — with AI as the primary tool, not a feature.</p>
      <a class="cv-link" href="/cv-hakon.pdf" target="_blank" rel="noopener">Download CV ↓</a>
    </div>
    
    <!-- Skills -->
    <div id="title-skills" class="section-title-container" data-section="skills">
      <div class="section-eyebrow">02 / STACK</div>
      <h2 class="section-title-main">STACK</h2>
      <div class="section-title-sub">POLYGLOT / FULLSTACK</div>
      <p class="section-title-desc">Python, TypeScript, Go, Elixir. React, Next.js, Svelte, Vue, Astro, Tailwind. FastAPI, Node.js, gRPC, WebSockets. PostgreSQL, Redis, Qdrant, ClickHouse. Google ADK 2.0, Gemini, Claude, Langfuse. Docker, Kubernetes, Sentry.</p>
    </div>
    
    <!-- Projects -->
    <div id="title-experience" class="section-title-container" data-section="experience">
      <div class="section-eyebrow">03 / PROJECTS</div>
      <h2 class="section-title-main">PROJECTS</h2>
      <div class="section-title-sub">LIVE / OPEN SOURCE</div>
      <ul class="section-title-list project-list">
        <li><span>[01]</span><span class="project-item"><a href="https://andartit.gamerzero.dev" target="_blank" rel="noopener">AndartIT ↗</a><em class="project-desc">Fullstack gaming community platform</em></span></li>
        <li><span>[02]</span><span class="project-item"><a href="https://provogatto.com" target="_blank" rel="noopener">Provogatto ↗</a><em class="project-desc">Italian restaurant site with reservations</em></span></li>
        <li><span>[03]</span><span class="project-item"><a href="https://github.com/Laurentzius/smartkeden" target="_blank" rel="noopener">Smartkeden ↗</a><em class="project-desc">AI customs: HS code classification, duty calc, docs</em></span></li>
        <li><span>[04]</span><span class="project-item"><a href="https://github.com/Laurentzius/flow-skills" target="_blank" rel="noopener">Flow-skills ↗</a><em class="project-desc">Reusable work-skills framework for AI agents</em></span></li>
        <li><span>[05]</span><span class="project-item"><span>Vetvoice</span><em class="project-desc">RAG/voice agent with ASR/TTS and telephony</em></span></li>
      </ul>
    </div>
    
    <!-- Contact -->
    <div id="title-contact" class="section-title-container" data-section="contact">
      <div class="section-eyebrow">04 / CONTACT</div>
      <h2 class="section-title-main">SIGNAL MODE</h2>
      <div class="section-title-sub">TRANSMISSION CHANNELS</div>
    </div>

    <!-- Voxel Case Study -->
    <div id="title-voxel" class="section-title-container" data-section="voxel">
      <div class="section-eyebrow">CASE / VOXEL</div>
      <h2 class="section-title-main">VOXEL ENGINE</h2>
      <div class="section-title-sub">REAL-TIME BROWSER ENGINE</div>
      <p class="section-title-desc">Chunk terrain, dynamic occlusion culling, custom physics, 60 FPS WebGL rendering.</p>
    </div>

    <!-- Shader Case Study -->
    <div id="title-shader" class="section-title-container" data-section="shader">
      <div class="section-eyebrow">CASE / SHADER</div>
      <h2 class="section-title-main">RAYMARCHER</h2>
      <div class="section-title-sub">SDF RENDERER PLAYGROUND</div>
      <p class="section-title-desc">Morphing metallic fields, soft shadows, and ambient occlusion in custom GLSL.</p>
    </div>

    <!-- Audio Case Study -->
    <div id="title-audio" class="section-title-container" data-section="audio">
      <div class="section-eyebrow">CASE / AUDIO</div>
      <h2 class="section-title-main">SPATIAL SYNTH</h2>
      <div class="section-title-sub">WEB AUDIO API</div>
      <p class="section-title-desc">FM synthesis, LFOs, and gain envelopes driven by canvas interactions.</p>
    </div>
  </div>

  <!-- HUD + Portfolio Navigation (React island, hydrated on load) -->
  <PortfolioHUD client:load />

  <script>
    import { gsap } from 'gsap';
    import { t_, onLocaleChange } from '../utils/i18n.js';

    const loader = document.getElementById('loader');

    // Helper to wrap each character in masked span elements
    function splitTextIntoSpans(element) {
      if (!element) return;
      const text = element.textContent.trim();
      element.innerHTML = '';
      
      text.split('').forEach(char => {
        const outerSpan = document.createElement('span');
        outerSpan.style.display = 'inline-block';
        outerSpan.style.overflow = 'hidden';
        outerSpan.style.verticalAlign = 'bottom';
        
        const innerSpan = document.createElement('span');
        innerSpan.textContent = char === ' ' ? '\u00A0' : char;
        innerSpan.style.display = 'inline-block';
        innerSpan.className = 'char-inner';
        
        outerSpan.appendChild(innerSpan);
        element.appendChild(outerSpan);
      });
    }

    // Apply i18n translations to all section title overlays
    function applyI18nToTitles() {
      document.querySelectorAll('.section-title-container[data-section]').forEach(container => {
        const sectionId = container.dataset.section;
        const s = t_(`sections.${sectionId}`);
        if (!s) return;

        const eyebrow = container.querySelector('.section-eyebrow');
        if (eyebrow && s.eyebrow) eyebrow.textContent = s.eyebrow;

        const mainTitle = container.querySelector('.section-title-main');
        if (mainTitle && s.main) mainTitle.textContent = s.main;

        const subTitle = container.querySelector('.section-title-sub');
        if (subTitle && s.sub) subTitle.textContent = s.sub;

        const desc = container.querySelector('.section-title-desc');
        if (desc && s.desc) desc.textContent = s.desc;

        if (s.list) {
          container.querySelectorAll('.project-desc').forEach((el, i) => {
            if (s.list[i]) el.textContent = s.list[i];
          });
        }
      });

      // Loader text
      const loaderText = document.querySelector('.loader-text');
      if (loaderText) loaderText.textContent = t_('loader');
      // CV download link label (About)
      const cvLink = document.querySelector('#title-about .cv-link');
      if (cvLink) cvLink.textContent = t_('cvLabel');

      // Re-split animated titles after text swap
      document.querySelectorAll('.section-title-container').forEach(container => {
        const mainTitle = container.querySelector('.section-title-main');
        if (mainTitle) splitTextIntoSpans(mainTitle);
        const subTitle = container.querySelector('.section-title-sub');
        if (subTitle) splitTextIntoSpans(subTitle);
      });
    }

    // Initial split
    applyI18nToTitles();

    let isCubeRestored = false;
    let activeSection = 'welcome';
    let sectionTimelines = {};

    const showSectionTitle = (sectionId) => {
      const el = document.getElementById(`title-${sectionId}`);
      if (!el) return;

      if (sectionTimelines[sectionId]) sectionTimelines[sectionId].kill();

      gsap.set(el, { visibility: 'visible', opacity: 1, y: 0 });

      const mainTitle = el.querySelector('.section-title-main');
      const subTitle = el.querySelector('.section-title-sub');
      const eyebrow = el.querySelector('.section-eyebrow');
      const desc = el.querySelector('.section-title-desc');
      const listItems = el.querySelectorAll('.section-title-list li');

      const tl = gsap.timeline();
      sectionTimelines[sectionId] = tl;

      const mainChars = mainTitle?.querySelectorAll('.char-inner');
      if (mainChars && mainChars.length > 0) {
        tl.fromTo(mainChars, 
          { y: '105%', opacity: 0, rotateX: -30, skewY: 7 }, 
          { y: '0%', opacity: 1, rotateX: 0, skewY: 0, duration: 0.8, stagger: 0.03, ease: 'power3.out' }
        );
      }

      const subChars = subTitle?.querySelectorAll('.char-inner');
      if (subChars && subChars.length > 0) {
        tl.fromTo(subChars, 
          { y: '105%', opacity: 0, rotateX: -30, skewY: 7 }, 
          { y: '0%', opacity: 1, rotateX: 0, skewY: 0, duration: 0.6, stagger: 0.012, ease: 'power3.out' },
          '-=0.45'
        );
      }

      if (eyebrow) {
        tl.fromTo(eyebrow,
          { opacity: 0, y: -10, letterSpacing: '8px' },
          { opacity: 0.58, y: 0, letterSpacing: '4px', duration: 0.8, ease: 'power2.out' },
          '-=0.6'
        );
      }

      if (desc) {
        tl.fromTo(desc, 
          { opacity: 0, y: 15 }, 
          { opacity: 1, y: 0, duration: 0.8, ease: 'power2.out' },
          '-=0.5'
        );
      }

      if (listItems && listItems.length > 0) {
        tl.fromTo(listItems,
          { opacity: 0, y: 15 },
          { opacity: 1, y: 0, duration: 0.6, stagger: 0.08, ease: 'power2.out' },
          '-=0.5'
        );
      }
    };

    const hideSectionTitle = (sectionId) => {
      const el = document.getElementById(`title-${sectionId}`);
      if (!el) return;

      if (sectionTimelines[sectionId]) sectionTimelines[sectionId].kill();

      const tl = gsap.timeline();
      sectionTimelines[sectionId] = tl;
      tl.to(el, {
        opacity: 0,
        y: -20,
        duration: 0.2,
        ease: 'power2.in',
        onComplete: () => {
          gsap.set(el, { visibility: 'hidden' });
        }
      });
    };

    // On locale change: re-apply text, re-split spans, re-show active section
    window.addEventListener('i18n:change', () => {
      applyI18nToTitles();
      if (isCubeRestored) {
        // Kill any running timeline on the active section first
        if (sectionTimelines[activeSection]) sectionTimelines[activeSection].kill();
        // Reset the active section element state so re-show animates cleanly
        const el = document.getElementById(`title-${activeSection}`);
        if (el) gsap.set(el, { visibility: 'hidden', opacity: 0 });
        showSectionTitle(activeSection);
      }
    });

    const initExperience = async () => {
      try {
        const { Experience } = await import('../core/Experience.js');
        const experience = new Experience('webgl');
        window.experience = experience;
        await experience.socialModels?.ready;
        
        if (experience.repair?.repairedCount === 3) {
          isCubeRestored = true;
          document.body.classList.add('cube-is-restored');
          updateSectionVisibility(experience.currentSection || 'welcome');
        }
      } catch (err) {
        console.error('Failed to load 3D Experience:', err);
      } finally {
        setTimeout(() => {
          if (loader) {
            loader.classList.add('fade-out');
          }
        }, 600);
      }
    };

    const updateSectionVisibility = (sectionId) => {
      if (isCubeRestored) {
        if (activeSection !== sectionId) {
          hideSectionTitle(activeSection);
          activeSection = sectionId;
          showSectionTitle(sectionId);
        } else {
          showSectionTitle(sectionId);
        }
      }
    };

    window.addEventListener('portfolio:section-change', (e) => {
      const sectionId = e.detail.sectionId;
      updateSectionVisibility(sectionId);
    });

    window.addEventListener('cube-restored', () => {
      isCubeRestored = true;
      document.body.classList.add('cube-is-restored');
      activeSection = window.experience?.currentSection || 'welcome';
      showSectionTitle(activeSection);
    });

    // Initialize visibility on load
    updateSectionVisibility('welcome');

    initExperience();
  </script>
</Layout>
